  "dependencies": {
    "@trystero-p2p/mqtt": "^0.25.1",
    "@trystero-p2p/nostr": "^0.25.1",
    "@trystero-p2p/ws-relay": "^0.25.1",
    "mqtt": "^5.10.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
