{
  "name": "chronicles-of-etheria-main",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:pvp-transport": "esbuild js/vendor/trystero-nostr.entry.js --bundle --format=esm --platform=browser --target=es2020 --minify --outfile=js/vendor/trystero-nostr.bundle.mjs",
    "build:pvp-transport-mqtt": "esbuild js/vendor/trystero-mqtt.entry.js --bundle --format=esm --platform=browser --target=es2020 --minify --outfile=js/vendor/trystero-mqtt.bundle.mjs",
    "build:pvp-transport-ws": "esbuild js/vendor/trystero-ws.entry.js --bundle --format=esm --platform=browser --target=es2020 --minify --outfile=js/vendor/trystero-ws.bundle.mjs",
    "build:pvp-mqtt-direct": "esbuild js/vendor/pvp-mqtt-direct.entry.js --bundle --format=esm --platform=browser --target=es2020 --minify --outfile=js/vendor/pvp-mqtt-direct.bundle.mjs",
    "build:pvp-vendor": "npm run build:pvp-mqtt-direct && npm run build:pvp-transport && npm run build:pvp-transport-mqtt && npm run build:pvp-transport-ws",
    "start:relay": "node server/pvp-relay.mjs",
    "test:crafting": "node scripts/test-crafting-profession.js",
    "test:jewelry": "node scripts/test-jewelry-equip.js",
    "test:pvp-transport": "node scripts/test-pvp-transport-adapter.js",
    "test:pvp": "node scripts/run-pvp-stress-suite.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikraOP/chronicles-of-etheria.git"
  },
